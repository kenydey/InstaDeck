# InstaDeck — 复制为 .env 后填写（勿提交真实密钥）

# 服务
INSTADECK_HOST=0.0.0.0
INSTADECK_PORT=8000
INSTADECK_DATA_DIR=./data
INSTADECK_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 默认 LLM（可被 settings API 覆盖；也可用环境变量作为初始默认值）
INSTADECK_OUTLINE_VENDOR_ID=openai
INSTADECK_OUTLINE_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Parser / Render 槽（可选）
INSTADECK_PARSER_ENABLED=false
INSTADECK_RENDER_LLM_ENABLED=false

# 调研（至少配置一种或依赖 mock）
TAVILY_API_KEY=
# BRAVE_API_KEY=
# SERPER_API_KEY=

# 图库
PEXELS_API_KEY=
PIXABAY_API_KEY=

# 多模态（参考图抽风格 FR-27，可选）
# OPENAI_API_KEY 复用或单独
INSTADECK_STYLE_VISION_MODEL=gpt-4o-mini
